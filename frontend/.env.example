# API base URL used by the frontend.
#
# Dev: leave UNSET to use Vite's proxy ("/api" -> http://localhost:8000),
#      which avoids CORS entirely. Optionally override the proxy target with
#      VITE_PROXY_TARGET.
# Prod/static build: set this to the API origin, e.g. http://localhost:8000
# VITE_API_BASE_URL=http://localhost:8000

# Override the dev proxy target (defaults to http://localhost:8000).
# VITE_PROXY_TARGET=http://localhost:8000
