# =============================================================================
# Multi-Agent RAG — environment configuration.
# Copy to `.env` (`cp .env.example .env`) and adjust as needed.
# Values here are consumed by docker-compose AND by the app (pydantic Settings).
# =============================================================================

# ---- Service identity ----
SERVICE_NAME=multi-agent-rag
ENVIRONMENT=local

# ---- Connection URLs (defaults target the compose service names) ----
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents

# ---- Embeddings (Gemini) ----
# Leave empty to use the deterministic local-fallback embedding (dev/CI).
# Set a real key to enable Gemini embeddings (models/text-embedding-004).
GEMINI_API_KEY=
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIM=3072
GEMINI_CHAT_MODEL=gemini-2.5-flash

# ---- Host port mappings ----
API_PORT=8000
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_METRICS_PORT=15692
REDIS_PORT=6379
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
FLOWER_PORT=5555
CELERY_EXPORTER_PORT=9808
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
PROMETHEUS_PORT=9090
# Frontend owns host :3000; Grafana is published on :3001.
GRAFANA_PORT=3001
FRONTEND_PORT=3000

# ---- Celery tuning ----
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SERIALIZER=json
CELERY_MAX_RETRIES=5
CELERY_RETRY_BACKOFF_BASE=2
CELERY_RETRY_BACKOFF_MAX=600

# ---- OpenTelemetry ----
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ---- Grafana admin ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
